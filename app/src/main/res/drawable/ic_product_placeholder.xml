<?xml version="1.0" encoding="utf-8"?>
<!-- Phase 6.8 — Coil `placeholder` drawable for product AsyncImage.
     A flat rounded-rect tile in the brand surface variant so the
     empty-image area is clearly distinguishable from the actual
     product image. No icon — Coil's contentDescription lives on
     the AsyncImage itself. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="12dp" />
    <solid android:color="#EEF3E6" />
    <stroke
        android:width="1dp"
        android:color="#0F000000" />
</shape>
